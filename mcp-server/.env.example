# ============================================================
# xcjs MCP server — environment variables
# 把这个文件复制成 .env (本地开发) 或者在 Render 后台填进去
# ============================================================

# GitHub Personal Access Token (需要 'repo' scope)
# 生成: https://github.com/settings/tokens
# ⚠️ 永远不要把真实 token commit 进仓库
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# 目标仓库的 owner (你的 GitHub 用户名或组织名)
GITHUB_OWNER=iristao215-hash

# 仓库名
GITHUB_REPO=xcjs

# 读取/写入哪个分支 (一般是 main)
GITHUB_BRANCH=main

# 可选: MCP 鉴权 token
# 设置后, Claude 连接时必须带 Bearer <token>
# 不设置就是裸奔, 任何人知道 URL 都能调用 (不推荐)
# 建议设个 16+ 位随机字符串
MCP_AUTH_TOKEN=

# 端口 (Render 会自动覆盖, 本地默认 3000)
PORT=3000
